-- Function: Create Line with Object Pooling Logic
local function Internal_CreateLine(thick, trans)
    local l = Drawing.new("Line")
    l.Thickness = thick or 2
    l.Transparency = trans or 1
    l.Visible = false
    return l
end

-- Function: Create Text with Object Pooling Logic
local function Internal_CreateText(size, centered)
    local t = Drawing.new("Text")
    t.Size = size or 13
    t.Center = centered or true
    t.Outline = true
    t.Visible = false
    t.Font = 3 -- Monospace
    return t
end

