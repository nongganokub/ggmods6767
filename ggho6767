-- Wall Check 2.0: Multi-Point Raycasting
local function IsPlayerVisible(targetRoot)
    if not _G.GOD_CORE_CONFIG.WallDetection then return true end
    
    local camPos = Camera.CFrame.Position
    local targetPos = targetRoot.Position
    local rayDir = (targetPos - camPos)
    
    local castParams = RaycastParams.new()
    castParams.FilterDescendantsInstances = {ClientPlayer.Character, targetRoot.Parent}
    castParams.FilterType = Enum.RaycastFilterType.Exclude
    castParams.IgnoreWater = true
    
    local result = Workspace:Raycast(camPos, rayDir, castParams)
    
    if result == nil then
        return true
    end
    return false
end

-- Item Detection Logic
local function GetEquippedToolName(p)
    local c = p.Character
    if c then
        local t = c:FindFirstChildOfClass("Tool")
        if t then
            return "[" .. string.upper(t.Name) .. "]"
        end
    end
    return "[EMPTY]"
end

-- [[ 6. ESP OBJECT CONSTRUCTOR ]] --

local function ConstructESP(player)
    if not GlobalESPTable[player] then
        GlobalESPTable[player] = {
            -- Box Infrastructure
            B1 = Internal_CreateLine(), B2 = Internal_CreateLine(),
            B3 = Internal_CreateLine(), B4 = Internal_CreateLine(),
            B5 = Internal_CreateLine(), B6 = Internal_CreateLine(),
            B7 = Internal_CreateLine(), B8 = Internal_CreateLine(),
            
            -- Information Display
            LabelName = Internal_CreateText(15),
            LabelItem = Internal_CreateText(12),
            
            -- Vital Signs
            BarBack = Internal_CreateLine(4, 0.5),
            BarFront = Internal_CreateLine(2, 1),
            
            -- Directional Tracers
            Tracer = Internal_CreateLine(1, 0.9)
        }
        -- Apply Initial States
        local o = GlobalESPTable[player]
        o.BarBack.Color = Color3.new(0,0,0)
        o.LabelItem.Color = _G.GOD_CORE_CONFIG.Theme_Item
    end
    return GlobalESPTable[player]
end

local function DestructESP(player)
    if GlobalESPTable[player] then
        for _, obj in pairs(GlobalESPTable[player]) do
            obj:Remove()
        end
        GlobalESPTable[player] = nil
    end
end

Players.PlayerRemoving:Connect(DestructESP)

-- [[ 7. SUPREME RENDER PROCESSING ]] --

RunService.RenderStepped:Connect(function()
    ViewportData = Camera.ViewportSize
    local MousePos = UserInputService:GetMouseLocation()
    
    -- FOV Update Logic
    FOV_Object.Position = MousePos
    FOV_Object.Radius = _G.GOD_CORE_CONFIG.FovCircleSize
    FOV_Object.Visible = _G.GOD_CORE_CONFIG.TeleportKey and _G.GOD_CORE_CONFIG.ClickBringActive
    FOV_Object.Color = CurrentChroma

    -- Speed Hack Processing
    if ClientPlayer.Character and ClientPlayer.Character:FindFirstChild("Humanoid") then
        ClientPlayer.Character.Humanoid.WalkSpeed = _G.GOD_CORE_CONFIG.SpeedValue
    end

    -- Main Player Loop
    for _, targetPlayer in ipairs(Players:GetPlayers()) do
        if targetPlayer == ClientPlayer then continue end
        
        local esp = ConstructESP(targetPlayer)
        local character = targetPlayer.Character
        local humanoid = character and character:FindFirstChild("Humanoid")
        local root = character and character:FindFirstChild("HumanoidRootPart")
        local head = character and character:FindFirstChild("Head")

        -- Dead or Null Check (Anti-Ghosting)
        if not character or not humanoid or not root or not head or humanoid.Health <= 0 then
            for _, draw in pairs(esp) do draw.Visible = false end
            continue
        end

        local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
        
        -- Visibility Color Logic
        local visibleStatus = IsPlayerVisible(root)
        local finalColor = visibleStatus and _G.GOD_CORE_CONFIG.Theme_Visible or _G.GOD_CORE_CONFIG.Theme_Hidden

        -- Hitbox Management
        if _G.GOD_CORE_CONFIG.HitboxActive then
            head.Size = Vector3.new(_G.GOD_CORE_CONFIG.HitboxRadius, _G.GOD_CORE_CONFIG.HitboxRadius, _G.GOD_CORE_CONFIG.HitboxRadius)
            head.Transparency = _G.GOD_CORE_CONFIG.HeadInvisible and 1 or 0.6
            head.CanCollide = false
            head.Massless = true
        else
            head.Size = Vector3.new(1.1, 1.1, 1.1)
            head.Transparency = 0
            head.CanCollide = true
        end

        if onScreen and _G.GOD_CORE_CONFIG.MasterSwitch then
            -- Coordinate Calculation
            local tPos = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3.2, 0))
            local bPos = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, -3.8, 0))
            
            local boxHeight = tPos.Y - bPos.Y
            local boxWidth = boxHeight / 1.6
            local cornerSize = boxWidth / 4

            -- Bring Module
            if _G.GOD_CORE_CONFIG.ClickBringActive and MouseActive then
                local mouseDist = (Vector2.new(screenPos.X, screenPos.Y) - MousePos).Magnitude
                if mouseDist <= _G.GOD_CORE_CONFIG.FovCircleSize then
                    local pRay = Camera:ViewportPointToRay(MousePos.X, MousePos.Y)
                    root.CFrame = CFrame.new(pRay.Origin + (pRay.Direction * _G.GOD_CORE_CONFIG.BringDistance))
                end
            end

            -- Visual: Corner Box
            if _G.GOD_CORE_CONFIG.BoxEnabled then
                -- Rendering 8 lines for corner box
                esp.B1.From = Vector2.new(screenPos.X - boxWidth/2, screenPos.Y - boxHeight/2); esp.B1.To = Vector2.new(screenPos.X - boxWidth/2 + cornerSize, screenPos.Y - boxHeight/2)
                esp.B2.From = Vector2.new(screenPos.X - boxWidth/2, screenPos.Y - boxHeight/2); esp.B2.To = Vector2.new(screenPos.X - boxWidth/2, screenPos.Y - boxHeight/2 + cornerSize)
                esp.B3.From = Vector2.new(screenPos.X + boxWidth/2, screenPos.Y - boxHeight/2); esp.B3.To = Vector2.new(screenPos.X + boxWidth/2 - cornerSize, screenPos.Y - boxHeight/2)
                esp.B4.From = Vector2.new(screenPos.X + boxWidth/2, screenPos.Y - boxHeight/2); esp.B4.To = Vector2.new(screenPos.X + boxWidth/2, screenPos.Y - boxHeight/2 + cornerSize)
                esp.B5.From = Vector2.new(screenPos.X - boxWidth/2, screenPos.Y + boxHeight/2); esp.B5.To = Vector2.new(screenPos.X - boxWidth/2 + cornerSize, screenPos.Y + boxHeight/2)
                esp.B6.From = Vector2.new(screenPos.X - boxWidth/2, screenPos.Y + boxHeight/2); esp.B6.To = Vector2.new(screenPos.X - boxWidth/2, screenPos.Y + boxHeight/2 - cornerSize)
                esp.B7.From = Vector2.new(screenPos.X + boxWidth/2, screenPos.Y + boxHeight/2); esp.B7.To = Vector2.new(screenPos.X + boxWidth/2 - cornerSize, screenPos.Y + boxHeight/2)
                esp.B8.From = Vector2.new(screenPos.X + boxWidth/2, screenPos.Y + boxHeight/2); esp.B8.To = Vector2.new(screenPos.X + boxWidth/2, screenPos.Y + boxHeight/2 - cornerSize)
                
                for i = 1, 8 do esp["B"..i].Visible = true; esp["B"..i].Color = finalColor end
            else
                for i = 1, 8 do esp["B"..i].Visible = false end
            end

            -- Visual: Information Stack
            local stackStart = screenPos.Y - boxHeight/2
            esp.LabelName.Visible = _G.GOD_CORE_CONFIG.NameEnabled
            esp.LabelName.Position = Vector2.new(screenPos.X, stackStart - 18)
            esp.LabelName.Text = targetPlayer.DisplayName
            esp.LabelName.Color = _G.GOD_CORE_CONFIG.Theme_Text

            esp.LabelItem.Visible = _G.GOD_CORE_CONFIG.ToolEnabled
            esp.LabelItem.Position = Vector2.new(screenPos.X, stackStart - 32)
            esp.LabelItem.Text = GetEquippedToolName(targetPlayer)

            -- Visual: Health Status
            if _G.GOD_CORE_CONFIG.HealthEnabled then
                local hRatio = humanoid.Health / humanoid.MaxHealth
                local xOffset = screenPos.X - boxWidth/2 - 6
                
                esp.BarBack.Visible = true; esp.BarBack.From = Vector2.new(xOffset, screenPos.Y + boxHeight/2); esp.BarBack.To = Vector2.new(xOffset, screenPos.Y - boxHeight/2)
                esp.BarFront.Visible = true; esp.BarFront.From = Vector2.new(xOffset, screenPos.Y + boxHeight/2); esp.BarFront.To = Vector2.new(xOffset, (screenPos.Y + boxHeight/2) - (boxHeight * hRatio))
                esp.BarFront.Color = Color3.fromRGB(255, 40, 40):Lerp(Color3.fromRGB(40, 255, 40), hRatio)
            else
                esp.BarBack.Visible = false; esp.BarFront.Visible = false
            end

            -- Visual: Tracer Line
            esp.Tracer.Visible = _G.GOD_CORE_CONFIG.TracerEnabled
            esp.Tracer.From = Vector2.new(ViewportData.X / 2, ViewportData.Y)
            esp.Tracer.To = Vector2.new(screenPos.X, screenPos.Y + boxHeight/2)
            esp.Tracer.Color = finalColor
        else
            for _, v in pairs(esp) do v.Visible = false end
        end
    end
end)

