    B.Font = "Gotham"
    B.TextXAlignment = "Left"
    Instance.new("UICorner", B).CornerRadius = UDim.new(0, 8)
    
    local Indicator = Instance.new("Frame", B)
    Indicator.Size = UDim2.new(0, 30, 0, 14)
    Indicator.Position = UDim2.new(1, -40, 0.5, -7)
    Indicator.BackgroundColor3 = _G.GOD_CORE_CONFIG[configKey] and Color3.fromRGB(220, 0, 0) or Color3.fromRGB(60, 60, 60)
    Instance.new("UICorner", Indicator).CornerRadius = UDim.new(1, 0)
    
    B.MouseButton1Click:Connect(function()
        _G.GOD_CORE_CONFIG[configKey] = not _G.GOD_CORE_CONFIG[configKey]
        Indicator.BackgroundColor3 = _G.GOD_CORE_CONFIG[configKey] and Color3.fromRGB(220, 0, 0) or Color3.fromRGB(60, 60, 60)
    end)
end

local function BuildSlider(label, min, max, current, configKey)
    local SFrame = Instance.new("Frame", Scroller)
    SFrame.Size = UDim2.new(0.94, 0, 0, 50)
    SFrame.BackgroundTransparency = 1
    
    local SLbl = Instance.new("TextLabel", SFrame)
    SLbl.Size = UDim2.new(1, 0, 0, 25)
    SLbl.Text = label .. ": " .. current
    SLbl.TextColor3 = Color3.new(0.9, 0.9, 0.9); SLbl.Font = "Gotham"; SLbl.TextSize = 12; SLbl.BackgroundTransparency = 1; SLbl.TextXAlignment = "Left"
    
    local Rail = Instance.new("Frame", SFrame)
    Rail.Size = UDim2.new(1, 0, 0, 5); Rail.Position = UDim2.new(0, 0, 0, 35); Rail.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    
    local Knob = Instance.new("TextButton", Rail)
    Knob.Size = UDim2.new(0, 14, 0, 14); Knob.Position = UDim2.new((current - min) / (max - min), -7, 0.5, -7); Knob.BackgroundColor3 = Color3.fromRGB(220, 0, 0); Knob.Text = ""
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
    
    local sliding = false
    Knob.MouseButton1Down:Connect(function() sliding = true end)
    UserInputService.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end end)
    
    RunService.RenderStepped:Connect(function()
        if sliding then
            local mouseX = UserInputService:GetMouseLocation().X
            local ratio = math.clamp((mouseX - Rail.AbsolutePosition.X) / Rail.AbsoluteSize.X, 0, 1)
            local newVal = math.floor(min + (ratio * (max - min)))
            Knob.Position = UDim2.new(ratio, -7, 0.5, -7); SLbl.Text = label .. ": " .. newVal; _G.GOD_CORE_CONFIG[configKey] = newVal
        end
    end)
end

