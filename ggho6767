local function BuildToggle(label, configKey)
    local B = Instance.new("TextButton", Scroller)
    B.Size = UDim2.new(0.94, 0, 0, 35)
    B.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
    B.Text = "  " .. label
