UserInputService.InputBegan:Connect(function(io, processed)
    if processed then return end
    
    if io.KeyCode == _G.GOD_CORE_CONFIG.ControlKey then
        _G.GOD_CORE_CONFIG.MenuState = not _G.GOD_CORE_CONFIG.MenuState
        Container.Visible = _G.GOD_CORE_CONFIG.MenuState
    end
    
    if io.KeyCode == _G.GOD_CORE_CONFIG.TeleportKey then
        _G.GOD_CORE_CONFIG.ClickBringActive = not _G.GOD_CORE_CONFIG.ClickBringActive
    end
    
    if io.UserInputType == Enum.UserInputType.MouseButton1 then
        MouseActive = true
    end
end)

